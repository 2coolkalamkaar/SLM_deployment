# ======================
# Terraform
# ======================

# Local .terraform directories (downloaded providers/modules)
**/.terraform/*

# Terraform lock file — keep this in version control
!.terraform.lock.hcl

# State files — contain sensitive infrastructure info, NEVER commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ======================
# Shell Scripts
# ======================

# Backup files
*.sh.bak

# ======================
# OS / Editor
# ======================

.DS_Store
.DS_Store?
._*
Thumbs.db

# VSCode
.vscode/

# JetBrains
.idea/

# ======================
# Secrets / Keys
# ======================

*.pem
*.key
*.env
.env
.env.*
credentials
